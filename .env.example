# Environment Variables for Travel Orchestration Platform
# Copy this file to .env and customize values as needed
# All variables are OPTIONAL - the application provides default values

# ============================================
# HashiCorp Vault Configuration
# ============================================
# Set to true to enable Vault integration, false to use defaults
VAULT_ENABLED=true

# Vault server URL
VAULT_URI=http://localhost:8200

# Vault authentication token
VAULT_TOKEN=your-vault-token

# ============================================
# PostgreSQL Database Configuration
# ============================================
# Only used when VAULT_ENABLED=false or to override Vault secrets
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mydatabase
DB_USER=myuser
DB_PASSWORD=mypassword

# ============================================
# Neo4j Database Configuration
# ============================================
# Only used when VAULT_ENABLED=false or to override Vault secrets
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# ============================================
# Rate Limiting Configuration (API Gateway)
# ============================================
# Controls how many requests per IP address are allowed
# RATE_LIMIT_CAPACITY: Maximum number of requests allowed per time window (default: 10)
# RATE_LIMIT_DURATION: Time window in seconds (default: 60)
# RATE_LIMIT_CAPACITY=10
# RATE_LIMIT_DURATION=60

# ============================================
# Logging Configuration
# ============================================
# Set to DEBUG to enable detailed logging
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
# LOGGING_LEVEL_ORG_SPRINGCLOUD_VAULT=DEBUG

# ============================================
# Stripe Configuration (Payment Service)
# ============================================
# Required when VAULT_ENABLED=false (or unset) and running payment-service.
# Obtain a key from https://dashboard.stripe.com/apikeys
# Must start with sk_test_ (test mode) or sk_live_ (live mode).
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# ============================================
# Notes
# ============================================
# 1. When VAULT_ENABLED=true, the application will fetch database credentials from Vault
#    at these paths:
#    - secret/database/postgres (for PostgreSQL)
#    - secret/database/neo4j (for Neo4j)
#
# 2. You can still override individual settings with environment variables even when
#    Vault is enabled (environment variables have highest priority)
#
# 3. For local development without Vault:
#    - Set VAULT_ENABLED=false (or leave it unset)
#    - Use the DB_* and NEO4J_* variables above, or use the defaults
#    - Set STRIPE_SECRET_KEY to a valid Stripe test key for payment-service
#
# 4. For production:
#    - Set VAULT_ENABLED=true
#    - Configure VAULT_URI and VAULT_TOKEN
#    - Store secrets in Vault
