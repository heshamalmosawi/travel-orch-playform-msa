services:
  postgres:
    image: "{{ postgres_image }}"
    container_name: "{{ postgres_container_name }}"
    restart: unless-stopped
    environment:
      POSTGRES_USER: "{{ postgres_user }}"
      POSTGRES_PASSWORD: "{{ postgres_password }}"
      POSTGRES_DB: "{{ postgres_database }}"
    ports:
      - "{{ postgres_port }}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql
    networks:
      - {{ db_network_name }}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user }} -d {{ postgres_database }}"]
      interval: 5s
      timeout: 5s
      retries: 5
      start_period: 10s

  neo4j:
    image: "{{ neo4j_image }}"
    container_name: "{{ neo4j_container_name }}"
    restart: unless-stopped
    environment:
      - NEO4J_AUTH={{ neo4j_auth }}
      - NEO4J_server_config_thread-pool_max-size=250
      - NEO4J_server_config_memory_heap_max__size=2G
    ports:
      - "{{ neo4j_http_port }}:7474"
      - "{{ neo4j_bolt_port }}:7687"
    volumes:
      - neo4j_data:/var/lib/neo4j
      - neo4j_logs:/var/lib/neo4j/logs
    networks:
      - {{ db_network_name }}
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:7474 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

networks:
  {{ db_network_name }}:
    external: true

volumes:
  postgres_data:
  neo4j_data:
  neo4j_logs:

