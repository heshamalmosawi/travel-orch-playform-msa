services:
  frontend-service:
    build: ./frontend/travel-orch
{% if microservices_replicas.get('frontend', 1) > 1 %}
    deploy:
      replicas: {{ microservices_replicas.get('frontend', 1) }}
{% else %}
    container_name: frontend-service
{% endif %}
    ports:
      - "4200:2122"
    depends_on:
      - apigateway-service
    networks:
      - microservices-network

  payment-service:
    build: ./backend/payment-service
{% if microservices_replicas.get('payment', 1) > 1 %}
    deploy:
      replicas: {{ microservices_replicas.get('payment', 1) }}
{% else %}
    container_name: payment-service
{% endif %}
    env_file:
      - .env
    environment:
      - STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
      - VAULT_ADDR=${VAULT_ADDR:-}
      - VAULT_TOKEN=${VAULT_TOKEN:-}
      - VAULT_SECRET_PATH=${VAULT_SECRET_PATH:-}
    networks:
      - microservices-network

  travel-service:
    build: ./backend/travel-service
{% if microservices_replicas.get('travel', 1) > 1 %}
    deploy:
      replicas: {{ microservices_replicas.get('travel', 1) }}
{% else %}
    container_name: travel-service
{% endif %}
    networks:
      - microservices-network

  user-service:
    build: ./backend/user-service
{% if microservices_replicas.get('user', 1) > 1 %}
    deploy:
      replicas: {{ microservices_replicas.get('user', 1) }}
{% else %}
    container_name: user-service
{% endif %}
    networks:
      - microservices-network

  apigateway-service:
    build: ./backend/apigateway-service
{% if microservices_replicas.get('gateway', 1) > 1 %}
    deploy:
      replicas: {{ microservices_replicas.get('gateway', 1) }}
{% else %}
    container_name: apigateway-service
{% endif %}
    ports:
      - "8443:8443"
    depends_on:
      - user-service
      - travel-service
      - payment-service
    networks:
      - microservices-network
    env_file:
      - .env
    environment:
      - SPRING_PROFILES_ACTIVE=docker

networks:
  microservices-network:
    driver: bridge
